{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/sprint-close-guard.ps1",
            "timeout": 10,
            "statusMessage": "Checking sprint-close governance"
          }
        ]
      }
    ]
  }
}
